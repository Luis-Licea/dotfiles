#!/usr/bin/env bash

OPTIONS=(--scan-intent Document --progress -d 'airscan:w1:Canon MG3200 series')
DATE=$(date -u '+%Y-%m-%d %H-%M-%S')

png() {
    scanimage "${OPTIONS[@]}" --output "$DATE.png" "$@"
}

pdf() {
    scanimage "${OPTIONS[@]}" --format pdf --batch="$DATE.pdf" --batch-prompt "$@"
}

photo() {
    png --resolution 600 --scan-intent Photo "$@"
}

check() {
    png -x 153  -y 70 "$@"
}

if [[ $1 = "-h" || $1 = "--help" ]]; then
    echo "Commands:"
    declare -F | sed "s/^declare -f/ /"
    scanimage "${OPTIONS[@]}" -h
else
    "$1" "${@:2}"
fi

