#!/usr/bin/env -S node --experimental-default-type=module

import {basename} from 'node:path';

import {spawnSync} from 'node:child_process';

function $(command) {
    return spawnSync(
        command,
        {
            shell: true,
            encoding: 'utf8',
            maxBuffer: Number.MAX_VALUE,
            stdio: ['inherit', 'pipe', 'inherit']
        }
    ).stdout.trimEnd();
}

function scan(...args) {
    const date = $("date -u '+%Y-%m-%d %H-%M-%S'")
    const file=`${date}.png`
    const options = args.join(" ")
    const command = `scanimage --scan-intent Document --progress -d 'airscan:w1:Canon MG3200 series' --output "${file}" --mode Gray ${options}`
    console.log(command);
    return $(command);
}

// Width and height in millimeters.
const dimensions = {
    "Usage": "scan-receipt <name>",
    "description": "Scan the receipt with the given dimensions",
    "Old Navy": [79, 274],
    "Walmart": [79, 192],
    "Family Dollar": [79, 110],
    "HEB": [79, 191],
    "Food Town": [79, 237],
    "Cheddar's Scratch Kitchen": [79, 205]
}

function scanFromName(receiptName) {
    const receipt=dimensions[receiptName];
    if (!receipt) {
        throw Error(`Invalid name: ${receipt}`)
    }
    const [width, height] = receipt;
    return scan(`-x ${width} -y ${height}`)
}

const [receiptName, ...scanOptions] = process.argv.slice(2);
if (!receiptName) {
    const folderName = basename(process.env.PWD);
    console.log(`Assuming: ${folderName}`);
    scanFromName(folderName);
} else if (['-h', '--helep'].includes(receiptName)) {
    console.log(dimensions)
    scan("-h")
} else {
    scanFromName(receiptName, scanOptions)
}


